    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst resultados = [];\n\nconst triggerNode = $('Detector Nuevos Casos').first();\nconst ruta = triggerNode?.json?.path || \"\";\nconst nombreOriginal = ruta ? ruta.split('/').pop().replace(/\\.[^/.]+$/, \"\") : \"Resultado_FV\";\n\nconst cimaItems = $('Extracción Secciones').all();\nconst interaccionesItems = $('Agente Interacciones').all();\n\nfor (let i = 0; i < items.length; i++) {\n    const item = items[i].json;\n\n    // Datos clínicos: del nodo de Limpieza, no del árbitro\n    const cimaData = cimaItems[i]?.json || {};\n    const notaInteracciones = interaccionesItems[i]?.json?.text || \"\";\n    const notaLimpia = notaInteracciones ? notaInteracciones.replace(/\\n/g, \" \").trim() : \"\";\n\n    // Datos del medicamento y RAM SIEMPRE desde Limpieza\n    const medicamento = cimaData.nombre_normalizado_cima \n        || cimaData.medicamento_sospechoso \n        || \"Desconocido\";\n    const ramReportada = cimaData.pseudo_meddra_pt || \"Desconocido\";\n    const sintomas = Array.isArray(cimaData.sintomas_originales_agrupados)\n        ? cimaData.sintomas_originales_agrupados.join(', ')\n        : (cimaData.sintomas_originales_agrupados || \"Desconocido\");\n    const fechaInicio = cimaData.fecha_inicio_cuadro || \"Desconocido\";\n    const fechaFin = cimaData.fecha_fin_cuadro || \"Desconocido\";\n    const mejoraRetirada = cimaData.mejora_tras_retirada || \"Desconocido\";\n    const idActual = cimaData.med_id || `med_${i}`;\n\n    try {\n        let dataArray;\n\n        // Caso A: el item ya viene parseado al primer nivel (output parser activo en el agente)\n        if (item.medicamento_evaluado || item.RAM_en_ficha_tecnica) {\n            dataArray = [item];\n        } else {\n            // Caso B: el item trae el JSON como string en 'output' o 'text' — hay que parsearlo\n            let textoCrudo = item.output || item.text || \"\";\n            textoCrudo = textoCrudo.replace(new RegExp('`{3}json', 'gi'), '').replace(new RegExp('`{3}', 'g'), '').trim();\n            textoCrudo = textoCrudo.replace(/:\\s*'((?:[^'\\\\]|\\\\.)*)'(\\s*[,\\n}\\]])/g, ': \"$1\"$2');\n\n            const idxArray = textoCrudo.indexOf('[');\n            const idxObjeto = textoCrudo.indexOf('{');\n\n            if (idxArray !== -1 && (idxObjeto === -1 || idxArray < idxObjeto)) {\n                const fin = textoCrudo.lastIndexOf(']');\n                if (fin === -1) throw new Error(\"Array JSON incompleto en la respuesta de la IA\");\n                dataArray = JSON.parse(textoCrudo.substring(idxArray, fin + 1));\n            } else if (idxObjeto !== -1) {\n                const fin = textoCrudo.lastIndexOf('}');\n                if (fin === -1) throw new Error(\"Objeto JSON incompleto en la respuesta de la IA\");\n                dataArray = [JSON.parse(textoCrudo.substring(idxObjeto, fin + 1))];\n            } else {\n                throw new Error(\"No hay JSON válido en la respuesta de la IA\");\n            }\n        }\n\n        for (const entry of dataArray) {\n            // SOLO del árbitro: veredicto de ficha técnica y observaciones\n            const enFicha = entry.RAM_en_ficha_tecnica || \"No determinado\";\n            const observacionesBase = entry.observaciones_clinicas || \"Sin observaciones\";\n            const observacionesFinales = notaLimpia\n                ? `${observacionesBase} | ${notaLimpia}`\n                : observacionesBase;\n\n            resultados.push({\n                json: {\n                    \"Medicamento\": medicamento,\n                    \"RAM_Reportada\": ramReportada,\n                    \"Sintomas_Paciente\": sintomas,\n                    \"Fecha_Inicio\": fechaInicio,\n                    \"Fecha_Fin\": fechaFin,\n                    \"Mejora_Retirada\": mejoraRetirada,\n                    \"En_Ficha_Tecnica\": enFicha,\n                    \"Observaciones_Clinicas\": observacionesFinales,\n                    \"med_id\": idActual,\n                    \"nombre_archivo_dinamico\": `${nombreOriginal}_ResultadoFinal.csv`\n                },\n                pairedItem: { item: i }\n            });\n        }\n    } catch (e) {\n        const observacionesCatch = notaLimpia\n            ? `Sin observaciones (fallo de parseo) | ${notaLimpia}`\n            : \"Sin observaciones (fallo de parseo)\";\n\n        resultados.push({\n            json: {\n                error: \"Error en formato final\",\n                detalle: e.message,\n                \"Medicamento\": medicamento,\n                \"RAM_Reportada\": ramReportada,\n                \"Sintomas_Paciente\": sintomas,\n                \"Fecha_Inicio\": fechaInicio,\n                \"Fecha_Fin\": fechaFin,\n                \"Mejora_Retirada\": mejoraRetirada,\n                \"En_Ficha_Tecnica\": \"No determinado\",\n                \"Observaciones_Clinicas\": observacionesCatch,\n                \"med_id\": idActual,\n                \"nombre_archivo_dinamico\": `${nombreOriginal}_ResultadoFinal.csv`\n            },\n            pairedItem: { item: i }\n        });\n    }\n}\n\n// Ordenar por med_id ascendente para mantener el orden canónico\nresultados.sort((a, b) => {\n    const idA = String(a.json.med_id || \"\");\n    const idB = String(b.json.med_id || \"\");\n    return idA.localeCompare(idB, undefined, { numeric: true });\n});\n\nreturn resultados;"

    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst parseoItems = $('Estructurador de Datos').all();\nconst diccionarioItems = $('Diccionario Clínico').all();\nconst resultados = [];\n\nfor (let i = 0; i < items.length; i++) {\n    const item = items[i];\n    \n    let datosDiccionario = {};\n    let datosClinicos = {};\n    \n    try {\n        datosDiccionario = $('Diccionario Clínico').itemMatching(i)?.json || {};\n    } catch (e) {\n        const idActual = item.json.med_id;\n        if (idActual) {\n            const m = diccionarioItems.find(it => it.json.med_id === idActual);\n            if (m) datosDiccionario = m.json;\n        }\n    }\n    \n    try {\n        datosClinicos = $('Estructurador de Datos').itemMatching(i)?.json || {};\n    } catch (e) {\n        const idActual = datosDiccionario.med_id || item.json.med_id;\n        if (idActual) {\n            const m = parseoItems.find(it => it.json.med_id === idActual);\n            if (m) datosClinicos = m.json;\n        }\n    }\n    \n    resultados.push({\n        json: {\n            ...datosClinicos,\n            ...datosDiccionario,\n            ...item.json\n        },\n        pairedItem: { item: i }\n    });\n}\n\n// Reordenar por medmed_id ascendente para mantener el orden original\nresultados.sort((a, b) => {\n    const idA = a.json.med_id || \"\";\n    const idB = b.json.med_id || \"\";\n    return idA.localeCompare(idB, undefined, { numeric: true });\n});\n\nreturn resultados;"

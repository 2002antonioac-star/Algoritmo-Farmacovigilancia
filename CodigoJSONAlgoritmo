    {
      "parameters": {
        "language": "python",
        "pythonCode": "import re\nimport html\n\nitems = _input.all()\nresultados = []\n\nfor item in items:\n    datos = dict(item.json)\n    \n    # CRÍTICO: Forzamos la conversión a string nativo de Python para evitar el error JsProxy\n    html_crudo = str(datos.get(\"html_crudo\", \"\"))\n\n    def extraer_y_limpiar(id_seccion, texto_html):\n        texto_html = str(texto_html)\n        patron_cabecera = re.compile(rf'<h[1-6][^>]*id=[\"\\']{id_seccion}[\"\\'][^>]*>.*?</h[1-6]>', re.IGNORECASE)\n        match_cabecera = patron_cabecera.search(texto_html)\n        \n        if not match_cabecera:\n            return \"Sección no encontrada.\"\n            \n        inicio = match_cabecera.end()\n        match_siguiente = re.search(r'<h[1-6][^>]*>', texto_html[inicio:], re.IGNORECASE)\n        \n        if match_siguiente:\n            fin = inicio + match_siguiente.start()\n            contenido = texto_html[inicio:fin]\n        else:\n            contenido = texto_html[inicio:]\n            \n        # Limpiar etiquetas HTML\n        texto_limpio = re.sub(r'<br\\s*/?>', '\\n', contenido, flags=re.IGNORECASE)\n        texto_limpio = re.sub(r'</p>', '\\n\\n', texto_limpio, flags=re.IGNORECASE)\n        texto_limpio = re.sub(r'<li[^>]*>', '\\n• ', texto_limpio, flags=re.IGNORECASE)\n        texto_limpio = re.sub(r'<[^>]*>?', '', texto_limpio)\n        texto_limpio = html.unescape(texto_limpio)\n        texto_limpio = re.sub(r'[ \\t]+', ' ', texto_limpio)\n        texto_limpio = re.sub(r'^ +', '', texto_limpio, flags=re.MULTILINE)\n        texto_limpio = re.sub(r'\\n{3,}', '\\n\\n', texto_limpio)\n        \n        return texto_limpio.strip()\n\n    # Extraer secciones clave\n    datos[\"cima_4_3_contraindicaciones\"] = extraer_y_limpiar(\"4.3\", html_crudo)\n    datos[\"cima_4_4_advertencias\"] = extraer_y_limpiar(\"4.4\", html_crudo)\n    datos[\"cima_4_8_reacciones_adversas\"] = extraer_y_limpiar(\"4.8\", html_crudo)\n    datos[\"cima_4_5_interacciones\"] = extraer_y_limpiar(\"4.5\", html_crudo)\n    \n    # Eliminar el HTML crudo para no saturar el JSON final\n    if \"html_crudo\" in datos:\n        del datos[\"html_crudo\"]\n        \n    resultados.append({\"json\": datos})\n\nreturn resultados"
      },

    {
      "parameters": {
        "jsCode": "// =============================================================\n// Selección de medicamento CIMA por vía/forma farmacéutica\n// =============================================================\n\nconst items = $input.all();\nconst resultados = [];\n\n// --- 1) Obtener pista IA de forma robusta ---\n// Va al nodo origen para evitar pérdidas en los HTTP intermedios\nfunction obtenerPista(itemData) {\n  let pista = '';\n  try {\n    pista = $('Diccionario Clínico').item.json.via_administracion_pista || '';\n  } catch (e) {\n    pista = itemData.via_administracion_pista || '';\n  }\n  return String(pista).toLowerCase().trim();\n}\n\n// --- 2) Categorizar pista (más específico primero) ---\nfunction categorizarPista(pista) {\n  if (!pista) return null;\n  if (/colirio|oft[aá]lmic[oa]/.test(pista))                                                  return 'oftalmica';\n  if (/[oó]tic[oa]|auricular|gotas?\\s*o[ií]do/.test(pista))                                   return 'otica';\n  if (/nasal/.test(pista))                                                                    return 'nasal';\n  if (/inhalat|inhalad|nebuli/.test(pista))                                                   return 'inhalatoria';\n  if (/intravenos|i\\.?v\\.?|perfusi[oó]n|inyectable|subcut[aá]nea/.test(pista))                return 'parenteral';\n  if (/t[oó]pic[oa]|cut[aá]ne[oa]|pomada|crema|gel|emulsi[oó]n|loci[oó]n|espuma|ung[uü]ento/.test(pista)) return 'topica';\n  if (/vaginal|[oó]vulo/.test(pista))                                                         return 'vaginal';\n  if (/rectal|supositorio/.test(pista))                                                       return 'rectal';\n  if (/oral|comprimido|c[aá]psula|granulad|jarabe|suspensi[oó]n|sublingual|bucal/.test(pista)) return 'oral';\n  return null;\n}\n\n// --- 3) ¿Coincide el medicamento con la categoría requerida? ---\n// IMPORTANTE: usa SIEMPRE viasAdministracion + formaFarmaceutica de CIMA,\n// nunca el nombre comercial (Daivobet contiene \"bet\" pero no es betametasona oral).\nfunction coincideCategoria(med, categoria) {\n  const vias  = (med.viasAdministracion || []).map(v => (v.nombre || '').toLowerCase()).join(' | ');\n  const forma = (med.formaFarmaceutica?.nombre || '').toLowerCase();\n  const info  = `${vias} || ${forma}`;\n\n  switch (categoria) {\n    case 'topica':       return /cut[aá]neo|t[oó]pic[oa]|pomada|crema|gel|emulsi[oó]n|loci[oó]n|espuma|ung[uü]ento/.test(info);\n    case 'oftalmica':    return /oft[aá]lmic[oa]|colirio|conjuntival/.test(info);\n    case 'otica':        return /[oó]tic[oa]|auricular/.test(info);\n    case 'nasal':        return /nasal/.test(info);\n    case 'inhalatoria':  return /inhalat|nebuli|respiratori/.test(info);\n    case 'parenteral':   return /intravenos|perfusi[oó]n|inyectable|intramuscular|subcut[aá]nea/.test(info);\n    case 'vaginal':      return /vaginal/.test(info);\n    case 'rectal':       return /rectal|supositorio/.test(info);\n    case 'oral':\n      // Oral exige vía oral Y excluye explícitamente otras vías\n      return /\\boral\\b|sublingual|bucal/.test(info)\n          && !/cut[aá]neo|oft[aá]lmic|intravenos|nasal|inhalat|vaginal|rectal/.test(info);\n    default: return true;\n  }\n}\n\n// --- 4) Scoring: prioriza comercializados y no revocados ---\nfunction puntuar(med, nombreBuscado) {\n  let s = 0;\n  \n  if (med.comerc === true)  s += 100;\n  if (med.estado?.rev)      s -=  50;\n  if (med.generico === true) s +=   1;\n  \n  if (nombreBuscado) {\n    const buscado = String(nombreBuscado).toLowerCase().trim();\n    const nombreCima = String(med.nombre || \"\").toLowerCase();\n    const primeraPalabra = nombreCima.split(/[\\s,\\d]+/)[0] || \"\";\n    \n    if (primeraPalabra === buscado) {\n      s += 500;\n    } else if (nombreCima.startsWith(buscado + \" \")) {\n      s += 300;\n    } else if (nombreCima.startsWith(buscado)) {\n      s += 100;\n    } else {\n      s -= 200;\n    }\n    \n    if (nombreCima.includes(\"/\")) {\n      s -= 300;\n    }\n    if (nombreCima.includes(\"+\")) {\n      s -= 300;\n    }\n  }\n  \n  return s;\n}\n\n// =============================================================\n// LOOP PRINCIPAL\n// =============================================================\nfor (let i = 0; i < items.length; i++) {\n  const data = items[i].json;\n\n  // Parse defensivo del payload CIMA\n  let busquedaCima;\n  try {\n    busquedaCima = typeof data.cima_search_data === 'string'\n      ? JSON.parse(data.cima_search_data)\n      : data.cima_search_data;\n  } catch (e) {\n    busquedaCima = null;\n  }\n  const medicamentos = busquedaCima?.resultados || data.resultados || [];\n\n  if (medicamentos.length === 0) {\n    data.nregistro_filtrado    = null;\n    data.debug_med_elegido     = null;\n    data.debug_motivo          = 'sin_resultados_cima';\n    resultados.push({ json: data });\n    continue;\n  }\n\n  // Categorizar pista\n  const pista     = obtenerPista(data);\n  const categoria = categorizarPista(pista);\n\n  // Filtrar por categoría\n  let candidatos = medicamentos;\n  let motivo     = 'sin_pista_se_toma_primero';\n\n  if (categoria) {\n    const filtrados = medicamentos.filter(m => coincideCategoria(m, categoria));\n    if (filtrados.length > 0) {\n      candidatos = filtrados;\n      motivo     = `filtro_${categoria}_ok`;\n    } else {\n      motivo     = `filtro_${categoria}_sin_coincidencias_fallback`;\n      // candidatos queda con todos (fallback)\n    }\n  }\n\n  // Ordenar por scoring (mejor primero)\ncandidatos.sort((a, b) => puntuar(b, data.nombre_limpio_cima) - puntuar(a, data.nombre_limpio_cima));\n  const ganador = candidatos[0];\n\n  // Salida + trazabilidad\n  data.nregistro_filtrado      = ganador.nregistro;\n  data.debug_med_elegido       = ganador.nombre;\n  data.debug_pista             = pista;\n  data.debug_categoria         = categoria;\n  data.debug_motivo            = motivo;\n  data.debug_total_candidatos  = candidatos.length;\n  data.debug_comercializado    = ganador.comerc === true;\n\n  resultados.push({ json: data });\n}\n\nreturn resultados;"
      },

        "jsCode": "function safeAll(nodeName) {\n    try { return $(nodeName).all(); } catch (e) { return []; }\n}\n\nconst triggerNode = $('Detector Nuevos Casos').first();\nconst ruta = triggerNode?.json?.path || \"\";\nconst nombreOriginal = ruta \n    ? ruta.split('/').pop().replace(/\\.[^/.]+$/, \"\") \n    : \"Resultado_FV\";\n\nconst diccionarioItems = safeAll('Diccionario Clínico');\nconst parseoItems      = safeAll('Estructurador de Datos');\n\nconst resultados = [];\n\nfor (let i = 0; i < diccionarioItems.length; i++) {\n    const datosDiccionario = diccionarioItems[i]?.json || {};\n    const datosOriginales  = parseoItems[i]?.json || {};\n\n    // _id: del Diccionario o del Parseo, con fallback al índice\n    const idActual = datosDiccionario.med_id \n        || datosOriginales.med_id \n        || `med_${i}`;\n\n    resultados.push({\n        json: {\n            \"Medicamento\": datosDiccionario.nombre_limpio_cima \n                || datosOriginales.medicamento_sospechoso \n                || \"Desconocido\",\n            \"RAM_Reportada\": datosOriginales.pseudo_meddra_pt || \"Desconocido\",\n            \"Sintomas_Paciente\": Array.isArray(datosOriginales.sintomas_originales_agrupados)\n                ? datosOriginales.sintomas_originales_agrupados.join(', ')\n                : (datosOriginales.sintomas_originales_agrupados || \"Desconocido\"),\n            \"Fecha_Inicio\": datosOriginales.fecha_inicio_cuadro || \"Desconocido\",\n            \"Fecha_Fin\": datosOriginales.fecha_fin_cuadro || \"Desconocido\",\n            \"Mejora_Retirada\": datosOriginales.mejora_tras_retirada || \"Desconocido\",\n            \"En_Ficha_Tecnica\": \"No se encontró ficha técnica\",\n            \"Observaciones_Clinicas\": \"Medicamento no encontrado en CIMA\",\n            \"med_id\": idActual,\n            \"nombre_archivo_dinamico\": `${nombreOriginal}_Huerfanos.csv`\n        }\n    });\n}\n\nreturn resultados;"
